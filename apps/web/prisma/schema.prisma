generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  CLIENT
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum LocationType {
  GYM
  HOME
  OUTDOOR
  ONLINE
  OTHER
}

enum PackageType {
  SESSION_BUNDLE
  MONTHLY
}

model Tenant {
  id         String    @id @default(cuid()) @map("_id")
  name       String
  slug       String    @unique
  email      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  users                   User[]
  clients                 Client[]
  packages                Package[]
  appointments            Appointment[]
  workoutTemplates        WorkoutTemplate[]
  workoutPlans            WorkoutPlan[]
  availabilityRules       TenantAvailabilityRule[]
  packagePurchases        PackagePurchase[]
  sessionCreditLedgers    SessionCreditLedger[]
  workoutSessions         WorkoutSession[]
  progressEntries         ProgressEntry[]
  notifications           Notification[]
  mobilePushDevices       MobilePushDevice[]
  tenantAvailabilitySlots TenantAvailabilitySlot[]
}

model User {
  id            String    @id @default(cuid()) @map("_id")
  tenantId      String?
  role          UserRole  @default(OWNER)
  email         String    @unique
  emailVerified DateTime?
  fullName      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  passwordHash  String?

  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  clients       Client[]
  accounts      Account[]
  sessions      Session[]
  appointments  Appointment[]
  notifications Notification[]
  mobilePushDevices MobilePushDevice[]

  @@index([tenantId])
}

model MobilePushDevice {
  id String @id @default(cuid()) @map("_id")

  tenantId String?
  userId   String

  expoPushToken String @unique
  platform      String
  deviceName    String?
  appOwnership  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  revokedAt  DateTime?

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User    @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@index([tenantId, userId, revokedAt])
}

model Client {
  id         String       @id @default(cuid()) @map("_id")
  tenantId   String?
  userId     String?
  slug       String
  fullName   String
  email      String?
  phone      String?
  status     ClientStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  archivedAt DateTime?

  bodyIssues ClientBodyIssue[]

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  appointments     Appointment[]
  packagePurchases PackagePurchase[]
  workoutPlans     WorkoutPlan[]
  workoutSessions  WorkoutSession[]
  progressEntries  ProgressEntry[]

  profile ClientProfile?
  metrics BodyMetricsEntry[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([userId])
}

model ClientProfile {
  id       String  @id @default(cuid()) @map("_id")
  tenantId String?
  clientId String  @unique

  heightMm  Int?
  sex       Sex?
  birthDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([tenantId])
}

model ClientInvite {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String
  token        String    @unique
  email        String?
  createdById  String
  usedByUserId String?
  usedAt       DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([createdById])
  @@index([email])
}

model BodyMetricsEntry {
  id       String @id @default(cuid()) @map("_id")
  tenantId String
  clientId String

  measuredAt DateTime @default(now())

  weightG    Int?
  waistMm    Int?
  hipsMm     Int?
  armLmm     Int?
  armRmm     Int?
  forearmLmm Int?
  forearmRmm Int?

  thighLmm  Int?
  thighRmm  Int?
  calfLmm   Int?
  calfRmm   Int?
  bodyFatBp Int?

  tbwBp        Int?
  icwBp        Int?
  ecwBp        Int?
  muscleMassG  Int?
  fatMassG     Int?
  ffmG         Int?
  bmrKcal      Int?
  visceralFat  Int?
  metabolicAge Int?
  phaseAngleBp Int?

  notes     String?
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([tenantId, clientId, measuredAt])
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELED
}

model Appointment {
  id       String @id @default(cuid()) @map("_id")
  tenantId String
  clientId String

  startsAt     DateTime
  endsAt       DateTime
  location     String?
  locationType LocationType
  notes        String?
  status       AppointmentStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  client        Client    @relation(fields: [clientId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])
  userId        String?
  priceCents    Int?
  currency      String?
  paidAt        DateTime?
  paymentMethod String?
  deletedAt     DateTime?

  workoutTemplateId String?          @db.ObjectId
  workoutTemplate   WorkoutTemplate? @relation(fields: [workoutTemplateId], references: [id])

  workoutSnapshotJson Json?
  appointmentWorkout  AppointmentWorkout?

  @@index([tenantId])
  @@index([clientId])
  @@index([startsAt])
}

model AppointmentWorkout {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String

  appointmentId    String  @unique
  planId           String  @db.ObjectId
  planVersionId    String  @db.ObjectId
  workoutSessionId String? @db.ObjectId

  appointment                Appointment                 @relation(fields: [appointmentId], references: [id])
  plan                       WorkoutPlan                 @relation(fields: [planId], references: [id])
  planVersion                WorkoutPlanVersion          @relation(fields: [planVersionId], references: [id])
  workoutSession             WorkoutSession?             @relation(fields: [workoutSessionId], references: [id])
  appointmentWorkoutItemLogs AppointmentWorkoutItemLog[]
  createdAt                  DateTime                    @default(now())

  @@index([tenantId, planId])
  @@index([tenantId, planVersionId])
  @@index([tenantId, workoutSessionId])
}

model AppointmentWorkoutItemLog {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String

  appointmentWorkoutId String             @db.ObjectId
  appointmentWorkout   AppointmentWorkout @relation(fields: [appointmentWorkoutId], references: [id])

  planVersionItemId String @db.ObjectId

  order Int

  nameSnapshot     String
  imageUrlSnapshot String?
  setsPlanned      Int?

  setsDone         Int?
  repsDoneBySet    String[]
  loadsKgDoneBySet Float[]
  restSecDoneBySet Int[]
  rpeDoneBySet     Int[]

  isCompleted Boolean @default(false)
  itemNotes   String?

  @@index([tenantId, appointmentWorkoutId])
}

model Package {
  id       String      @id @default(cuid()) @map("_id")
  tenantId String
  name     String
  type     PackageType

  sessionCount Int?
  bundlePrice  Float?

  monthlyPrice        Float?
  monthlySessionCount Int?

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  archivedAt DateTime?
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  purchases  PackagePurchase[]

  @@index([tenantId])
}

model PackagePurchase {
  id                String    @id @default(cuid()) @map("_id")
  tenantId          String
  clientId          String
  packageId         String
  remainingSessions Int?
  active            Boolean   @default(true)
  startedAt         DateTime  @default(now())
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())

  tenant  Tenant                @relation(fields: [tenantId], references: [id])
  client  Client                @relation(fields: [clientId], references: [id])
  package Package               @relation(fields: [packageId], references: [id])
  ledger  SessionCreditLedger[]

  @@index([tenantId])
  @@index([clientId])
}

model SessionCreditLedger {
  id                String   @id @default(cuid()) @map("_id")
  tenantId          String
  packagePurchaseId String
  delta             Int
  reason            String?
  createdAt         DateTime @default(now())

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  packagePurchase PackagePurchase @relation(fields: [packagePurchaseId], references: [id])

  @@index([tenantId])
}

model WorkoutTemplateDay {
  id         String                    @id @default(cuid()) @map("_id")
  templateId String
  name       String
  order      Int
  exercises  WorkoutTemplateExercise[]

  template WorkoutTemplate @relation(fields: [templateId], references: [id])
}

model WorkoutTemplateExercise {
  id      String @id @default(cuid()) @map("_id")
  dayId   String
  name    String
  sets    Int
  reps    Int?
  restSec Int?
  order   Int

  day WorkoutTemplateDay @relation(fields: [dayId], references: [id])
}

model WorkoutSession {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String
  clientId      String
  planId        String  @db.ObjectId
  planVersionId String  @db.ObjectId
  appointmentId String?

  status String @default("planned")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items WorkoutSessionItem[]

  plan                WorkoutPlan          @relation(fields: [planId], references: [id])
  planVersion         WorkoutPlanVersion   @relation(fields: [planVersionId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  client              Client               @relation(fields: [clientId], references: [id])
  appointmentWorkouts AppointmentWorkout[]
  workoutSetLogs      WorkoutSetLog[]

  @@index([tenantId, clientId])
  @@index([tenantId, planId])
  @@index([tenantId, appointmentId])
}

model WorkoutSessionItem {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String
  sessionId String         @db.ObjectId
  session   WorkoutSession @relation(fields: [sessionId], references: [id])

  order Int

  globalExerciseId String? @db.ObjectId
  tenantExerciseId String? @db.ObjectId

  nameSnapshot     String
  tipsSnapshot     String?
  imageUrlSnapshot String?
  tagsSnapshot     String[]

  sets         Int?
  reps         String?
  restSec      Int?
  tempo        String?
  rpe          Int?
  loadsKg      Float[]
  restSecBySet Int[]
  itemNotes    String?

  performedLoadsKg      Float[]
  performedRestSecBySet Int[]
  performedRepsBySet    String[]

  @@index([tenantId, sessionId])
}

model WorkoutSetLog {
  id           String @id @default(cuid()) @map("_id")
  sessionId    String
  exerciseName String
  setNumber    Int
  weight       Float?
  reps         Int?
  rir          Int?
  rpe          Float?

  session WorkoutSession @relation(fields: [sessionId], references: [id])
}

model ProgressEntry {
  id        String   @id @default(cuid()) @map("_id")
  tenantId  String
  clientId  String
  weight    Float?
  notes     String?
  createdAt DateTime @default(now())

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  client Client          @relation(fields: [clientId], references: [id])
  photos ProgressPhoto[]

  @@index([tenantId])
  @@index([clientId])
}

model ProgressPhoto {
  id        String   @id @default(cuid()) @map("_id")
  entryId   String
  fileKey   String
  angle     String?
  createdAt DateTime @default(now())

  entry ProgressEntry @relation(fields: [entryId], references: [id])
}

model MagicLinkToken {
  id        String   @id @default(cuid()) @map("_id")
  email     String
  token     String   @unique
  tenantId  String
  clientId  String?
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Exercise {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  coachTips   String?
  imageUrl    String?

  tags         String[]
  tagsText     String?
  isArchived   Boolean       @default(false)
  workoutItems WorkoutItem[]

  @@index([tenantId, name])
}

model WorkoutTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title      String
  notes      String?
  isArchived Boolean @default(false)

  items               WorkoutItem[]
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  appointments        Appointment[]
  workoutTemplateDays WorkoutTemplateDay[]
  workoutPlans        WorkoutPlan[]

  @@index([tenantId, createdAt])
}

model WorkoutItem {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String

  workoutId String          @db.ObjectId
  workout   WorkoutTemplate @relation(fields: [workoutId], references: [id])

  globalExerciseId String?         @db.ObjectId
  globalExercise   GlobalExercise? @relation(fields: [globalExerciseId], references: [id])

  tenantExerciseId String?         @db.ObjectId
  tenantExercise   TenantExercise? @relation(fields: [tenantExerciseId], references: [id])

  order        Int
  sets         Int?
  reps         String?
  restSec      Int?
  restSecBySet Int[]
  tempo        String?
  rpe          Int?
  itemNotes    String?
  nameSnapshot String?
  tipsSnapshot String?
  exercise     Exercise? @relation(fields: [exerciseId], references: [id])
  exerciseId   String?   @db.ObjectId
  loadsKg      Float[]

  @@index([tenantId, workoutId])
}

model WorkoutPlan {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String
  clientId String

  workoutTemplateId String?          @db.ObjectId
  workoutTemplate   WorkoutTemplate? @relation(fields: [workoutTemplateId], references: [id])

  title   String
  notes   String?
  status  String    @default("active")
  startAt DateTime  @default(now())
  endAt   DateTime?

  currentVersion Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions        WorkoutPlanVersion[]
  appointments    AppointmentWorkout[]
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  client          Client               @relation(fields: [clientId], references: [id])
  workoutSessions WorkoutSession[]

  @@index([tenantId, clientId])
  @@index([tenantId, workoutTemplateId])
}

model WorkoutPlanVersion {
  id       String      @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String
  planId   String      @db.ObjectId
  plan     WorkoutPlan @relation(fields: [planId], references: [id])

  version Int
  title   String
  notes   String?

  createdByUserId String?

  createdAt DateTime @default(now())

  items               WorkoutPlanVersionItem[]
  appointmentWorkouts AppointmentWorkout[]
  workoutSessions     WorkoutSession[]

  @@unique([planId, version])
  @@index([tenantId, planId, createdAt])
}

model WorkoutPlanVersionItem {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String

  planVersionId String             @db.ObjectId
  planVersion   WorkoutPlanVersion @relation(fields: [planVersionId], references: [id])

  order Int

  workoutKey          String?
  workoutNameSnapshot String?
  workoutOrder        Int?    @default(0)

  globalExerciseId String?         @db.ObjectId
  globalExercise   GlobalExercise? @relation(fields: [globalExerciseId], references: [id])

  tenantExerciseId String?         @db.ObjectId
  tenantExercise   TenantExercise? @relation(fields: [tenantExerciseId], references: [id])

  nameSnapshot     String
  tipsSnapshot     String?
  imageUrlSnapshot String?
  tagsSnapshot     String[]

  sets    Int?
  reps    String?
  restSec Int?
  tempo   String?
  rpe     Int?

  loadsKg      Float[]
  restSecBySet Int[]

  itemNotes String?

  @@index([tenantId, planVersionId])
  @@index([tenantId, planVersionId, workoutOrder, order])
}

model GlobalExercise {
  id                      String                   @id @default(auto()) @map("_id") @db.ObjectId
  slug                    String                   @unique
  name                    String
  description             String?
  imageUrl                String?
  tags                    String[]                 @default([])
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  workoutItems            WorkoutItem[]
  tenantExerciseOverrides TenantExerciseOverride[]
  workoutPlanVersionItems WorkoutPlanVersionItem[]
}

model TenantExerciseOverride {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId         String
  globalExerciseId String         @db.ObjectId
  globalExercise   GlobalExercise @relation(fields: [globalExerciseId], references: [id])

  nameOverride        String?
  descriptionOverride String?
  coachTips           String?
  imageUrlOverride    String?
  tagsOverride        String[] @default([])

  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, globalExerciseId])
}

model TenantExercise {
  id                      String                   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId                String
  name                    String
  description             String?
  coachTips               String?
  imageUrl                String?
  tags                    String[]                 @default([])
  tagsText                String                   @default("")
  isArchived              Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  workoutItems            WorkoutItem[]
  workoutPlanVersionItems WorkoutPlanVersionItem[]
}

model TenantAvailabilityRule {
  id       String @id @default(cuid()) @map("_id")
  tenantId String

  weekday  Int
  startMin Int
  endMin   Int

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, weekday, isActive])
}

model TenantAvailabilitySlot {
  id       String @id @default(cuid()) @map("_id")
  tenantId String

  date    DateTime
  startAt DateTime
  endAt   DateTime

  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, startAt, endAt])
}

enum BodySide {
  LEFT
  RIGHT
  MIDLINE
}

enum IssueType {
  PAIN
  STIFFNESS
  INJURY
  POST_OP
  OTHER
}

model ClientBodyIssue {
  id       String @id @default(cuid()) @map("_id")
  tenantId String
  clientId String

  zoneKey String
  side    BodySide @default(MIDLINE)

  type     IssueType @default(PAIN)
  severity Int?
  notes    String?
  active   Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([tenantId, clientId])
  @@index([tenantId, zoneKey])
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELED
  APPOINTMENT_RESCHEDULED
  PAYMENT_MARKED
  GENERIC
}

model Notification {
  id       String           @id @default(cuid()) @map("_id")
  tenantId String
  userId   String
  type     NotificationType @default(GENERIC)

  title String
  body  String?

  href String?

  appointmentId String?
  clientId      String?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, readAt, createdAt])
  @@index([tenantId, appointmentId])
  @@index([tenantId, clientId])
}

model PasswordResetToken {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}
